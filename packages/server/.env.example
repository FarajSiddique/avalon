# ─────────────────────────────────────────────────────────────────────────────
# Avalon Server — environment variables
# Copy this file to .env and fill in the values before starting the server.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# Secret used to sign and verify JWTs.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be kept secret in production. The server will refuse to start without it.
JWT_SECRET=replace-with-a-long-random-secret

# ── Optional (have safe defaults for local development) ───────────────────────

# Port the NestJS HTTP server listens on.
# Railway injects PORT automatically; omit or leave unset locally.
# Default: 3000
# PORT=3000

# Allowed CORS origin for the React client.
# In production set this to your Vercel deployment URL, e.g. https://avalon.vercel.app
# Default (development only): http://localhost:5173
# CLIENT_ORIGIN=http://localhost:5173
